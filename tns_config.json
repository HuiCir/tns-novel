{
  "workspace": ".",
  "product_doc": "task.md",
  "thread": 2,
  "threads": 2,
  "refresh_hours": 5,
  "refresh_minutes": null,
  "refresh_seconds": null,
  "permission_mode": "acceptEdits",
  "effort": "high",
  "success_interval_seconds": 1,
  "idle_interval_seconds": 60,
  "max_budget_usd": null,
  "agent_provider": {
    "name": "claude",
    "command": "claude",
    "model": "sonnet"
  },
  "permissions": {
    "default_profile": "standard",
    "profiles": {
      "standard": {
        "permission_mode": "acceptEdits",
        "allowed_bash_commands": [
          "pwd",
          "ls",
          "cat",
          "sed",
          "rg",
          "find",
          "git",
          "node",
          "tns",
          "claude",
          "wc",
          "mkdir"
        ],
        "workspace_only": true
      }
    },
    "section_profiles": []
  },
  "monitor": {
    "heartbeat_seconds": 30,
    "max_agent_runtime_seconds": 1800,
    "kill_grace_seconds": 15
  },
  "exploration": {
    "enabled": false,
    "allow_taskx": true,
    "taskx_filename": "taskx.md",
    "max_rounds_per_window": 1,
    "agent": "tns-executor",
    "plan_taskx": true,
    "taskx_min_score": 75,
    "taskx_branch_dir": ".tns/taskx",
    "require_taskx_deliverables": true
  },
  "tmux": {
    "enabled": false,
    "auto_create": true,
    "session_name": "",
    "window_name": "tns-novel",
    "socket_name": "",
    "manage_runner": false,
    "runner_window_name": "tns-runner"
  },
  "workflow": {
    "entry": "executor",
    "max_steps_per_run": 6,
    "agents": [
      {
        "id": "executor",
        "agent": "tns-executor",
        "schema": "executor",
        "prompt_mode": "executor",
        "transitions": [
          {
            "field": "outcome",
            "equals": "blocked",
            "set_status": "blocked",
            "summary_field": "summary",
            "review_field": "blocker",
            "end": true
          },
          {
            "field": "clean_state",
            "equals": false,
            "set_status": "pending",
            "summary_field": "summary",
            "end": true
          },
          {
            "field": "ready_for_verification",
            "equals": false,
            "set_status": "pending",
            "summary_field": "summary",
            "end": true
          },
          {
            "next": "verifier"
          }
        ]
      },
      {
        "id": "verifier",
        "agent": "tns-verifier",
        "schema": "verifier",
        "prompt_mode": "verifier",
        "transitions": [
          {
            "field": "status",
            "equals": "pass",
            "set_status": "done",
            "summary_field": "summary",
            "review_value": "",
            "set_verified_at": true,
            "end": true
          },
          {
            "field": "status",
            "in": [
              "fail",
              "blocked"
            ],
            "set_status": "needs_fix",
            "summary_field": "summary",
            "review_field": "review_note",
            "append_review": true,
            "end": true
          }
        ]
      }
    ]
  },
  "attempts": {
    "max_attempts_per_section": 3
  },
  "preflight": {
    "required_files": [
      "task.md"
    ],
    "required_directories": [
      ".claude/skills/novel-check",
      ".tns",
      "draft/chapters",
      "story_bible"
    ]
  },
  "validators": [
    {
      "id": "story-bible-complete",
      "stage": "post_run",
      "kind": "file_exists",
      "path": "story_bible/world.md",
      "description": "world setting exists"
    },
    {
      "id": "story-bible-characters",
      "stage": "post_run",
      "kind": "file_exists",
      "path": "story_bible/characters.md",
      "description": "character profiles exist"
    },
    {
      "id": "chapters-all-exist",
      "stage": "post_run",
      "kind": "file_exists",
      "path": "draft/chapters/chapter-05.md",
      "description": "final chapter exists (pipeline complete)"
    },
    {
      "id": "story-bible-outline",
      "stage": "post_run",
      "kind": "file_exists",
      "path": "story_bible/outline.md",
      "description": "story outline exists"
    },
    {
      "id": "chapter-01-exists",
      "stage": "post_run",
      "kind": "file_exists",
      "path": "draft/chapters/chapter-01.md",
      "description": "chapter 01 file exists"
    },
    {
      "id": "chapter-02-exists",
      "stage": "post_run",
      "kind": "file_exists",
      "path": "draft/chapters/chapter-02.md",
      "description": "chapter 02 file exists"
    },
    {
      "id": "chapter-03-exists",
      "stage": "post_run",
      "kind": "file_exists",
      "path": "draft/chapters/chapter-03.md",
      "description": "chapter 03 file exists"
    },
    {
      "id": "chapter-04-exists",
      "stage": "post_run",
      "kind": "file_exists",
      "path": "draft/chapters/chapter-04.md",
      "description": "chapter 04 file exists"
    },
    {
      "id": "chapter-05-exists",
      "stage": "post_run",
      "kind": "file_exists",
      "path": "draft/chapters/chapter-05.md",
      "description": "chapter 05 file exists (pipeline complete)"
    }
  ],
  "command_bridge": {
    "command_sets": {
      "check-continuity": {
        "id": "check-continuity",
        "description": "validate novel continuity across story bible and chapter drafts",
        "command": [
          "node",
          ".claude/skills/novel-check/check_novel.js"
        ],
        "commands": [],
        "timeout_seconds": 30
      },
      "demo-fsm": {
        "id": "demo-fsm",
        "description": "dry-run FSM pipeline validation before live execution",
        "command": [
          "node",
          ".claude/skills/novel-fsm-demo/demo_fsm.js",
          "--speed",
          "100",
          "--steps",
          "15"
        ],
        "commands": [],
        "timeout_seconds": 30
      }
    },
    "hooks": [
      {
        "id": "ensure-chapter-dir",
        "timing": "pre_step",
        "section_ids": [
          "sec-006",
          "sec-007",
          "sec-008",
          "sec-009",
          "sec-010"
        ],
        "command": "mkdir -p draft/chapters",
        "description": "ensure chapter output directory exists before any chapter write"
      },
      {
        "id": "check-novel-continuity",
        "timing": "post_step",
        "section_ids": [
          "sec-003",
          "sec-005",
          "sec-006",
          "sec-007",
          "sec-008",
          "sec-009",
          "sec-010"
        ],
        "command": "node .claude/skills/novel-check/check_novel.js",
        "description": "run novel continuity check via novel-check skill after each content-producing step"
      }
    ]
  },
  "policy": {
    "preflight_failure": {
      "action": "block_section",
      "review_prefix": "Preflight failed"
    },
    "command_failure": {
      "action": "mark_needs_fix",
      "review_prefix": "Command hook failed"
    },
    "outside_workspace_violation": {
      "action": "block_section",
      "review_prefix": "Workspace boundary violation"
    },
    "validator_failure": {
      "preflight": {
        "action": "block_section",
        "review_prefix": "Preflight validator failed"
      },
      "pre_step": {
        "action": "mark_needs_fix",
        "review_prefix": "Pre-step validator failed"
      },
      "post_step": {
        "action": "mark_needs_fix",
        "review_prefix": "Post-step validator failed"
      },
      "post_run": {
        "action": "mark_needs_fix",
        "review_prefix": "Post-run validator failed"
      }
    },
    "attempt_exhaustion": {
      "action": "block_section",
      "review_prefix": "Max attempts exhausted"
    }
  },
  "outputs": {
    "write_section_outputs": true
  },
  "execution": {
    "long_running": {
      "agent": "tns-executor",
      "workspace": "primary",
      "persists_state": true,
      "gc_after_run": false,
      "max_parallel": 2
    },
    "temporary": {
      "agent": "tns-temp-executor",
      "workspace": "temporary",
      "persists_state": false,
      "must_report_to": "tns-executor",
      "gc_after_run": true,
      "max_parallel": 2
    },
    "verifier": {
      "agent": "tns-verifier",
      "workspace": "primary",
      "persists_state": false,
      "must_report_to": "tns-executor",
      "gc_after_run": true,
      "max_runtime_seconds": 600,
      "max_parallel": 1
    }
  },
  "externals": {
    "tools": [
      {
        "name": "node",
        "required": true,
        "purpose": "run continuity checker and FSM demo scripts"
      },
      {
        "name": "tns",
        "required": true,
        "purpose": "TNS 1.0.3 compile, doctor, and runner commands"
      },
      {
        "name": "claude",
        "required": true,
        "purpose": "Claude Code executor and verifier agent invocations"
      }
    ],
    "skills": [
      {
        "name": "novel-check",
        "required": true,
        "purpose": "continuity validation for novel story bible and chapter drafts",
        "source_kind": "skills_dir",
        "source_path": ".claude/skills",
        "path": ".claude/skills/novel-check"
      },
      {
        "name": "novel-fsm-demo",
        "required": false,
        "purpose": "dry-run FSM pipeline validation before live execution",
        "source_kind": "skills_dir",
        "source_path": ".claude/skills",
        "path": ".claude/skills/novel-fsm-demo"
      }
    ],
    "mcp": []
  },
  "skillbases": {
    "use_default_sources": true,
    "sources": [],
    "selection": {
      "mode": "explicit",
      "max_matches_per_section": 2,
      "min_score": 0.22,
      "verifier_mode": "none"
    }
  },
  "injections": {
    "default_profile": null,
    "profiles": {
      "compiler": {
        "skills": [
          "tns-program-compiler"
        ],
        "description": "Compiler skill for compile synthesis passes."
      },
      "planner": {
        "skills": [
          "tns-task-planner"
        ],
        "description": "Planner skill for task quality and task.md planning passes."
      },
      "executor_task": {
        "skills": [
          "novel-check"
        ],
        "description": "Executor skills: novel continuity validation injected into writing sections."
      },
      "verifier_audit": {
        "skills": [
          "novel-check"
        ],
        "description": "Verifier skills: independent continuity audit."
      }
    },
    "rules": [
      {
        "match_mode": "compile",
        "profile": "compiler"
      },
      {
        "match_mode": "plan",
        "profile": "planner"
      },
      {
        "match_mode": "executor",
        "match_title": "Chapter 0",
        "profile": "executor_task"
      },
      {
        "match_mode": "verifier",
        "profile": "verifier_audit"
      }
    ]
  },
  "program": {
    "entry": "sec-001",
    "context": {},
    "states": [
      {
        "id": "sec-001",
        "type": "task",
        "description": "Story premise & world setting",
        "on_enter": [
          {
            "op": "set",
            "path": "phase",
            "value": "setup"
          }
        ],
        "transitions": [
          {
            "to": "sec-002"
          }
        ]
      },
      {
        "id": "sec-002",
        "type": "task",
        "description": "Global protocol for all sections",
        "transitions": [
          {
            "to": "sec-003"
          }
        ]
      },
      {
        "id": "sec-003",
        "type": "task",
        "description": "Story outline & act structure",
        "on_enter": [
          {
            "op": "set",
            "path": "phase",
            "value": "outline"
          }
        ],
        "transitions": [
          {
            "to": "sec-004"
          }
        ]
      },
      {
        "id": "sec-004",
        "type": "task",
        "description": "Character profiles",
        "on_enter": [
          {
            "op": "set",
            "path": "phase",
            "value": "characters"
          }
        ],
        "transitions": [
          {
            "to": "sec-005"
          }
        ]
      },
      {
        "id": "sec-005",
        "type": "task",
        "description": "Character review & finalization",
        "transitions": [
          {
            "to": "sec-006"
          }
        ]
      },
      {
        "id": "sec-006",
        "type": "task",
        "description": "Chapter 01: Opening — establish world, inciting incident",
        "on_enter": [
          {
            "op": "set",
            "path": "current_chapter",
            "value": 1
          },
          {
            "op": "inc",
            "path": "loop_count",
            "by": 1
          }
        ],
        "parallel": {
          "resource": "chapter:01"
        },
        "transitions": [
          {
            "to": "sec-007"
          }
        ]
      },
      {
        "id": "sec-007",
        "type": "task",
        "description": "Chapter 02: Escalation — deepen mystery, raise stakes",
        "on_enter": [
          {
            "op": "set",
            "path": "current_chapter",
            "value": 2
          }
        ],
        "parallel": {
          "resource": "chapter:02"
        },
        "transitions": [
          {
            "to": "sec-008"
          }
        ]
      },
      {
        "id": "sec-008",
        "type": "task",
        "description": "Chapter 03: Reversal — truth revealed, loyalties shift",
        "on_enter": [
          {
            "op": "set",
            "path": "current_chapter",
            "value": 3
          }
        ],
        "parallel": {
          "resource": "chapter:03"
        },
        "transitions": [
          {
            "to": "sec-009"
          }
        ]
      },
      {
        "id": "sec-009",
        "type": "task",
        "description": "Chapter 04: Confrontation — climax, cost of truth",
        "on_enter": [
          {
            "op": "set",
            "path": "current_chapter",
            "value": 4
          }
        ],
        "parallel": {
          "resource": "chapter:04"
        },
        "transitions": [
          {
            "to": "sec-010"
          }
        ]
      },
      {
        "id": "sec-010",
        "type": "task",
        "terminal": true,
        "description": "Chapter 05: Resolution — escape, transformation, open ending",
        "on_enter": [
          {
            "op": "set",
            "path": "current_chapter",
            "value": 5
          }
        ],
        "parallel": {
          "resource": "chapter:05"
        },
        "transitions": []
      }
    ],
    "max_steps": 100,
    "threads": 2,
    "parallel": {
      "mode": "auto",
      "max_threads": 2
    }
  }
}